# RAFIQ local/private development

# Supabase local database connection used by server-side API only.
RAFIQ_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:55422/postgres

# Private API server
RAFIQ_API_HOST=127.0.0.1
RAFIQ_API_PORT=8056
RAFIQ_DEPLOYMENT_MODE=private_local
RAFIQ_PUBLIC_CONTENT_ENABLED=false

# Mobile/web client points to the API, not directly to Supabase private schemas.
EXPO_PUBLIC_API_URL=http://127.0.0.1:8056

# Never commit real production keys.
SUPABASE_SERVICE_ROLE_KEY=
OPENAI_API_KEY=
